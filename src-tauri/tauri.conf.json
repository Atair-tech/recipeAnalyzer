{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Recipe Analyzer",
  "version": "0.1.21",
  "identifier": "com.atair.recipeanalyzer",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Recipe Analyzer",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../data/recipe_analyzer.db": "data/recipe_analyzer.db",
      "../data/recipes.xlsx": "data/recipes.xlsx"
    },
    "externalBin": [
      "binaries/recipe-backend"
    ],
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}

